# Copiá este archivo a .env y completá los valores.
# NUNCA subas .env a git.

# Clave secreta para sesiones Flask.
# Generá una con: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=

# Credenciales de acceso
SERVER_USERNAME=admin

# Hash de la contraseña (PBKDF2-SHA256 via Werkzeug).
# Generá uno con: python -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('tu_contraseña'))"
PASSWORD_HASH=

# Tamaño máximo de subida en MB (por defecto 500)
MAX_CONTENT_MB=500

# Carpeta donde se guardan los archivos (relativa al directorio del proyecto)
UPLOAD_FOLDER=uploads

# Dirección y puerto en que escucha el servidor
HOST=0.0.0.0
PORT=5000
